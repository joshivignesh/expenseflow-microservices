# =============================================================================
# .env.example — copy to .env and fill in real values
# .env is gitignored — NEVER commit real secrets
# =============================================================================

# SQL Server SA password — must meet SQL Server complexity requirements
# Min 8 chars, uppercase, lowercase, digit, special char
SQL_SA_PASSWORD=YourStrong_Passw0rd!

# JWT signing secret — shared across all services that validate tokens
# Min 32 chars, random string recommended
JWT_SECRET_KEY=replace-with-a-secure-random-string-min-32-chars
