{
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SAME_SECRET_AS_ALL_SERVICES",
    "Issuer": "ExpenseFlow.Identity",
    "Audience": "ExpenseFlow.Client"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "RateLimiterPolicy": "auth",
        "Match": {
          "Path": "/identity/auth/{**catch-all}",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "expense-route": {
        "ClusterId": "expense-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/expenses/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/expenses/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://identity-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "expense-cluster": {
        "Destinations": {
          "expense-service": {
            "Address": "http://expense-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
