{
  "ConnectionStrings": {
    "ExpenseDb": "Server=localhost;Database=ExpenseFlowExpenseDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SAME_SECRET_AS_IDENTITY_SERVICE",
    "Issuer": "ExpenseFlow.Identity",
    "Audience": "ExpenseFlow.Client"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
